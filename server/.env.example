# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lensai

# Cloudinary (get from cloudinary.com dashboard)
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret

# HuggingFace (get from huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Optional HuggingFace model/provider settings for caption generation
HF_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
HF_PROVIDERS=together,novita

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# Allowed frontend origins (comma separated). Supports wildcards.
# Example: https://*.vercel.app allows all Vercel preview deployments.
CLIENT_URLS=http://localhost:5173,https://your-app.vercel.app,https://*.vercel.app,https://your-app.netlify.app,https://*.netlify.app

# Port
PORT=5000

# Runtime mode
NODE_ENV=development
